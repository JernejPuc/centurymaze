<?xml version="1.0"?>
<robot name="cube">
<link name="cube">
    <visual>
        <origin xyz="0 0 0"/>
        <geometry>
            <mesh filename="cube.obj" scale="0.1 0.1 0.1"/>
        </geometry>
    </visual>
    <collision>
        <origin xyz="0 0 0"/>
        <geometry>
            <box size="0.2 0.2 0.2"/>
        </geometry>
    </collision>
    <inertial>
        <density value="1000.0"/>
    </inertial>
</link>
</robot>
