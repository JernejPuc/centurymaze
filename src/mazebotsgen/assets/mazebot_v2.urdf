<?xml version="1.0"?>
<robot name="bot">
<link name="body">
    <inertial>
        <mass value="3.0"/>
        <origin rpy="0 0 0" xyz="0 0 0.125"/>
        <inertia ixx="0.02882" ixy="0.0" ixz="0.0" iyy="0.02882" iyz="0.0" izz="0.045"/>
    </inertial>
    <visual>
        <origin rpy="-1.57079632675 0 0" xyz="0 0 0.164"/>
        <geometry>
            <mesh filename="bot/cube.obj" scale="0.15 0.05 0.15"/>
