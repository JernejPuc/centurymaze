    <collision>
        <origin rpy="0 0 0" xyz="0 0 0.164"/>
        <geometry>
            <box size="0.3 0.3 0.1"/>
        </geometry>
    </collision>
</link>
<link name="motors_fused">
    <visual>
        <origin rpy="-1.57079632675 0 0" xyz="0 0 -0.04"/>
        <geometry>
            <mesh filename="bot/cube.obj" scale="0.11 0.04 0.106"/>
        </geometry>
    </visual>
</link>
