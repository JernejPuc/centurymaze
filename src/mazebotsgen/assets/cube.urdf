<?xml version="1.0"?>
<robot name="cube">
<link name="cube">
    <visual>
        <origin xyz="0 0 0"/>
        <geometry>
            <mesh filename="bot/cube.obj" scale="0.225 0.225 0.225"/>
        </geometry>
    </visual>
    <collision>
        <origin xyz="0 0 0"/>
        <geometry>
            <box size="0.45 0.45 0.45"/>
        </geometry>
    </collision>
    <inertial>
        <density value="1000.0"/>
    </inertial>
</link>
</robot>
